# .releaseignore — gitignore-style exclusions for release-artifact-packaging
# Patterns without "/" match at any depth (auto-expanded to **/variant).
# Patterns with "/" match at top level (literal gitignore semantics).

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.venv/
venv/

# Secrets (NEVER include, even in no-redact mode)
.env
.env.*
secrets/

# VCS
.git/
.gitignore
.gitattributes

# OS
.DS_Store
Thumbs.db

# Build artifacts
build/
dist/
.tox/
*.log
