# OpenRouter API key for the LLM fact verifier.
# Get from: https://openrouter.ai/keys
# Copy this file to /opt/searxng/.env_llm and fill in the real value.
# Permissions: chmod 600 /opt/searxng/.env_llm

# OpenRouter (required)
LLM_API_KEY=sk-or-...e-me

# Verifier model (default: meta-llama/llama-3.1-8b-instruct:free)
# Override via LLM_MODEL env var (e.g. google/gemini-2.0-flash-exp:free)
LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Optional alias if you prefer the standard env name
# OPENROUTER_API_KEY=sk-or-...e-me
