# Residential proxy credentials (template — fill your own)
# Get from: https://your-proxy-provider.com (we used proxy.market during dev)
PROXY_HOST=pool.proxy.example.com
PROXY_PORT=10000
PROXY_USER=your_username
PROXY_PASS=your_password

# File permissions: chmod 600
# Used by: docker-compose.yml (env_file), llm_verifier.py (fallback)
# Per-engine proxy in settings.yml uses these via $PROXY_USER/$PROXY_PASS interpolation
